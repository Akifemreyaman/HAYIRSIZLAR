@model HayirsizlarApp.Models.FeedViewModel
@{
    ViewData["Title"] = "Ana Akış";
}

<div class="dashboard-layout">
    <!-- Left Column: Branding, User Metadata, and Post Composer -->
    <div class="left-column">
        <div>
            <h1 style="font-size: 2.8rem; font-weight: 900; line-height: 1; text-transform: uppercase; margin-bottom: 25px; letter-spacing: -1px;">
                HAYIRSIZLAR<br/>GÜNLÜĞÜ
            </h1>
            
            <div class="profile-info-grid">
                <div class="info-item">
                    <div class="label">Yazar (Zat)</div>
                    <div class="value">@Model.CurrentUser.DisplayName</div>
                </div>
                <div class="info-item">
                    <div class="label">Kullanıcı</div>
                    <div class="value">@@@Model.CurrentUser.Username</div>
                </div>
                <div class="info-item">
                    <div class="label">Format</div>
                    <div class="value">Kişisel Günlük</div>
                </div>
                <div class="info-item">
                    <div class="label">Yazar Kadrosu</div>
                    <div class="value">@Model.TotalUserCount / 4</div>
                </div>
                <div class="info-item" style="grid-column: span 2;">
                    <div class="label">Mevcut Ruh Hali</div>
                    <div class="value">@(Model.CurrentUser.MoodStatus ?? "BELİRSİZ 💭")</div>
                </div>
            </div>
        </div>

        <!-- Compose Tweet Card -->
        <div class="brutalist-card" style="box-shadow: 6px 6px 0px 0px var(--dark-black); margin-bottom: 0;">
            <h2 style="font-size: 1.25rem; font-weight: 900; text-transform: uppercase; margin-bottom: 15px; border-bottom: 3px solid black; padding-bottom: 5px;">
                GÜNLÜK NOTU EKLE
            </h2>
            
            <form asp-action="PostTweet" method="post" enctype="multipart/form-data">
                <input type="hidden" id="QuoteTweetId" name="NewTweet.QuoteTweetId" value="@(ViewBag.QuoteTweetId ?? "")" />
                
                <!-- Quote Preview Box -->
                <div id="quotePreviewBox" style="display: @(ViewBag.QuoteTweetId != null ? "block" : "none"); border: 2px dashed var(--dark-black); background-color: #fafafa; padding: 10px; margin-bottom: 15px; position: relative;">
                    <button type="button" onclick="cancelQuote()" style="position: absolute; right: 5px; top: 5px; background: none; border: none; font-size: 1.2rem; font-weight: bold; cursor: pointer;">×</button>
                    <div style="font-size: 0.8rem; font-weight: bold; margin-bottom: 4px; text-transform: uppercase;">Alıntılanan Günlük:</div>
                    <div id="quotePreviewAuthor" style="font-size: 0.75rem; color: #555; font-weight: bold;">@(ViewBag.QuoteAuthor != null ? $"Gönderen: {ViewBag.QuoteAuthor}" : "")</div>
                    <div id="quotePreviewText" style="font-size: 0.85rem; font-style: italic; max-height: 80px; overflow-y: auto;">@ViewBag.QuoteContent</div>
                </div>

                <div class="form-group" style="margin-bottom: 15px;">
                    <textarea asp-for="NewTweet.Content" class="form-control" placeholder="Bugün neler oldu? Mahrem notlarını buraya bırak..."></textarea>
                    <span asp-validation-for="NewTweet.Content" class="validation-error"></span>
                </div>

                <!-- Custom Upload Area -->
                <div class="form-group" style="margin-bottom: 15px;">
                    <label for="MediaFile" class="custom-file-upload">
                        📷 RESİM VEYA 🎥 VİDEO SEÇ
                    </label>
                    <input type="file" id="MediaFile" name="NewTweet.MediaFile" accept="image/*,video/*" style="display: none;" />
                    <span asp-validation-for="NewTweet.MediaFile" class="validation-error"></span>

                    <!-- Frontend File Preview -->
                    <div class="file-preview" id="mediaPreviewContainer">
                        <button class="file-preview-remove" id="removePreviewBtn">×</button>
                        <img id="previewImage" src="" alt="Image Preview" style="display: none;" />
                        <video id="previewVideo" src="" style="display: none;" muted playsinline></video>
                    </div>
                </div>

                <button type="submit" class="nav-btn btn-black" style="width: 100%; font-size: 1rem; padding: 12px; display: flex; justify-content: center; align-items: center; gap: 8px;">
                    YAYINLA <span style="font-size: 1.1rem;">→</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Right Column: Scrollable Post Stream -->
    <div class="right-column">
        <div class="tweet-stream">
            @if (!Model.Tweets.Any())
            {
                <div class="no-tweets">
                    <p style="margin-bottom: 10px; font-size: 2rem;">■</p>
                    <p>Henüz kimse bir şey yazmamış.</p>
                    <p style="font-size: 0.85rem; color: #555; margin-top: 5px;">Sol paneldeki formu kullanarak ilk günlüğü sen yaz!</p>
                </div>
            }
            else
            {
                @foreach (var tweet in Model.Tweets)
                {
                    <div class="tweet-card">
                        <!-- Header info -->
                        <div class="tweet-header">
                            <div class="tweet-author-info">
                                <div class="tweet-avatar" style="background-color: @(tweet.User?.AvatarColor ?? "#FFE600")">
                                    @(tweet.User?.DisplayName.Substring(0, Math.Min(2, tweet.User.DisplayName.Length)).ToUpper() ?? "??")
                                </div>
                                <div class="tweet-author-names">
                                    <span class="tweet-displayname">
                                        @(tweet.User?.DisplayName ?? "Bilinmeyen Yazar")
                                        @if (!string.IsNullOrEmpty(tweet.User?.MoodStatus))
                                        {
                                            <span class="user-mood-badge">💭 @tweet.User.MoodStatus</span>
                                        }
                                    </span>
                                    <span class="tweet-username">@@@(tweet.User?.Username ?? "username")</span>
                                </div>
                            </div>
                            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 5px;">
                                <span class="tweet-date">@tweet.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                @if (tweet.IsEdited)
                                {
                                    <span class="tweet-edited-badge" style="font-size: 0.7rem; font-weight: 800; text-transform: uppercase; background-color: var(--primary-yellow); border: 1px solid var(--dark-black); padding: 1px 5px;" title="Düzenlenme tarihi: @tweet.EditedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")">(düzenlendi)</span>
                                }
                            </div>
                        </div>

                        <!-- Video / Image Retro Container -->
                        @if (tweet.MediaType != MediaType.None && !string.IsNullOrEmpty(tweet.MediaUrl))
                        {
                            <div class="retro-tv-player">
                                <div class="media-display-container">
                                    <div class="scanlines-overlay"></div>
                                    
                                    @if (tweet.MediaType == MediaType.Image)
                                    {
                                        <img src="@tweet.MediaUrl" alt="Tweet Image" />
                                    }
                                    else if (tweet.MediaType == MediaType.Video)
                                    {
                                        <video src="@tweet.MediaUrl" playsinline></video>
                                        <div class="video-play-overlay"></div>
                                    }
                                </div>

                                <!-- Custom Vintage Control Panel -->
                                <div class="player-dashboard">
                                    <div class="dashboard-row-upper">
                                        <span class="tv-brand-sticker">HAYIRSIZLAR-TV</span>
                                        <span>STATUS: @(tweet.MediaType == MediaType.Video ? "PLAY READY" : "STATIC")</span>
                                    </div>
                                    
                                    <div class="dashboard-row-middle">
                                        <div class="timeline-slider-container">
                                            <div class="timeline-track-bg">
                                                <div class="timeline-fill"></div>
                                            </div>
                                            <input type="range" class="timeline-input" min="0" max="100" value="0" @(tweet.MediaType == MediaType.Image ? "disabled" : "") />
                                        </div>
                                        <div class="time-counter">
                                            @(tweet.MediaType == MediaType.Video ? "00:00 / --:--" : "IMAGE VIEW")
                                        </div>
                                    </div>

                                    <div class="dashboard-row-lower">
                                        <div class="controls-left">
                                            <button class="player-btn btn-play-toggle" type="button" @(tweet.MediaType == MediaType.Image ? "disabled" : "")>▶</button>
                                            <button class="player-btn btn-mute-toggle" type="button" @(tweet.MediaType == MediaType.Image ? "disabled" : "")>🔊</button>
                                        </div>
                                        <div class="volume-container">
                                            <span style="font-size: 0.7rem;">VOL</span>
                                            <input type="range" class="volume-slider" min="0" max="1" step="0.1" value="1" @(tweet.MediaType == MediaType.Image ? "disabled" : "") />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Text content -->
                        <div class="tweet-content-container" id="tweet-content-container-@tweet.Id">
                            @if (!string.IsNullOrEmpty(tweet.Content))
                            {
                                @if (tweet.Content.Length > 300)
                                {
                                    <div class="tweet-content short-content">
                                        @Html.Raw(HayirsizlarApp.Helpers.MentionHelper.HighlightMentions(tweet.Content.Substring(0, 300)))...
                                        <button class="read-more-btn" onclick="toggleReadMore(this)">Devamını Oku</button>
                                    </div>
                                    <div class="tweet-content full-content" style="display: none;">
                                        @Html.Raw(HayirsizlarApp.Helpers.MentionHelper.HighlightMentions(tweet.Content))
                                        <button class="read-less-btn" onclick="toggleReadMore(this)">Daha Az Göster</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="tweet-content">@Html.Raw(HayirsizlarApp.Helpers.MentionHelper.HighlightMentions(tweet.Content))</div>
                                }
                            }
                        </div>

                        <!-- Quoted Tweet Box if any -->
                        @if (tweet.QuoteTweet != null)
                        {
                            <div class="quoted-tweet-box" style="border: 2px solid var(--dark-black); background-color: #fcfcfc; padding: 12px; margin: 15px 0 10px 0; box-shadow: 3px 3px 0px 0px var(--dark-black); font-size: 0.9rem;">
                                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px; font-weight: 800;">
                                    <div class="tweet-avatar" style="width: 22px; height: 22px; font-size: 0.7rem; line-height: 22px; margin-right: 0; background-color: @(tweet.QuoteTweet.User?.AvatarColor ?? "#FFE600")">
                                        @(tweet.QuoteTweet.User?.DisplayName.Substring(0, Math.Min(2, tweet.QuoteTweet.User.DisplayName.Length)).ToUpper() ?? "??")
                                    </div>
                                    <span>@(tweet.QuoteTweet.User?.DisplayName ?? "Bilinmeyen Yazar")</span>
                                    <span style="color: #555; font-weight: 500;">@@@(tweet.QuoteTweet.User?.Username ?? "username")</span>
                                    <span style="margin-left: auto; font-size: 0.75rem; color: #666;">@tweet.QuoteTweet.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                                <div class="quoted-content" style="font-style: italic; margin-left: 30px;">
                                    @Html.Raw(HayirsizlarApp.Helpers.MentionHelper.HighlightMentions(tweet.QuoteTweet.Content))
                                </div>
                            </div>
                        }

                        <!-- Inline Edit form, hidden by default -->
                        @if (tweet.UserId == Model.CurrentUser.Id)
                        {
                            <div class="edit-tweet-form-container" id="edit-tweet-form-container-@tweet.Id" style="display: none; margin-bottom: 20px;">
                                <form asp-action="EditTweet" method="post">
                                    <input type="hidden" name="id" value="@tweet.Id" />
                                    <div class="form-group">
                                        <textarea name="content" class="form-control" style="min-height: 100px;">@tweet.Content</textarea>
                                    </div>
                                    <div style="display: flex; gap: 10px;">
                                        <button type="submit" class="nav-btn btn-yellow" style="padding: 6px 12px; font-size: 0.8rem; box-shadow: 2px 2px 0px 0px var(--dark-black);">KAYDET</button>
                                        <button type="button" class="nav-btn btn-white" onclick="cancelEditTweet(@tweet.Id)" style="padding: 6px 12px; font-size: 0.8rem; box-shadow: 2px 2px 0px 0px var(--dark-black);">İPTAL</button>
                                    </div>
                                </form>
                            </div>
                        }

                        <!-- Actions / Details, Edit & Delete buttons -->
                        <div class="tweet-footer">
                            <div class="tweet-footer-left">
                                <a asp-controller="Home" asp-action="Tweet" asp-route-id="@tweet.Id" class="nav-btn btn-white" style="font-size: 0.75rem; padding: 6px 12px; box-shadow: 2px 2px 0px 0px var(--dark-black); text-decoration: none;">
                                    💬 CEVAPLAR (@(tweet.Replies?.Count ?? 0))
                                </a>
                                <button type="button" class="nav-btn btn-white" onclick="openQuote(@tweet.Id, '@(tweet.User?.DisplayName)', '@(Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(tweet.Content ?? "")))')" style="font-size: 0.75rem; padding: 6px 12px; box-shadow: 2px 2px 0px 0px var(--dark-black);">
                                    🔁 ALINTILA
                                </button>
                                @{
                                    var likesCount = tweet.Reactions?.Count(r => r.IsLike) ?? 0;
                                    var dislikesCount = tweet.Reactions?.Count(r => !r.IsLike) ?? 0;
                                    var userReaction = tweet.Reactions?.FirstOrDefault(r => r.UserId == Model.CurrentUser.Id);
                                    var hasLiked = userReaction != null && userReaction.IsLike;
                                    var hasDisliked = userReaction != null && !userReaction.IsLike;
                                }
                                <form asp-action="React" method="post" style="display: inline;">
                                    <input type="hidden" name="id" value="@tweet.Id" />
                                    <input type="hidden" name="isLike" value="true" />
                                    <button type="submit" class="nav-btn @(hasLiked ? "btn-yellow" : "btn-white")" style="font-size: 0.75rem; padding: 6px 12px; box-shadow: 2px 2px 0px 0px var(--dark-black);">
                                        👍 @likesCount
                                    </button>
                                </form>
                                <form asp-action="React" method="post" style="display: inline;">
                                    <input type="hidden" name="id" value="@tweet.Id" />
                                    <input type="hidden" name="isLike" value="false" />
                                    <button type="submit" class="nav-btn @(hasDisliked ? "btn-yellow" : "btn-white")" style="font-size: 0.75rem; padding: 6px 12px; box-shadow: 2px 2px 0px 0px var(--dark-black);">
                                        👎 @dislikesCount
                                    </button>
                                </form>
                                @if (tweet.UserId == Model.CurrentUser.Id)
                                {
                                    <button class="nav-btn btn-white" onclick="startEditTweet(@tweet.Id)" style="font-size: 0.75rem; padding: 6px 12px; box-shadow: 2px 2px 0px 0px var(--dark-black);">DÜZENLE</button>
                                }
                            </div>
                            @if (tweet.UserId == Model.CurrentUser.Id)
                            {
                                <form asp-action="DeleteTweet" method="post" onsubmit="return confirm('Bu günlüğe silmek istediğinden emin misin?');">
                                    <input type="hidden" name="id" value="@tweet.Id" />
                                    <button type="submit" class="delete-tweet-btn">SİL</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Pagination Bar -->
        @if (Model.TotalPages > 1)
        {
            <div class="brutalist-pagination">
                @if (Model.CurrentPage > 1)
                {
                    <a href="?page=@(Model.CurrentPage - 1)" class="nav-btn btn-white">← ÖNCEKİ</a>
                }
                else
                {
                    <span class="btn-disabled">← ÖNCEKİ</span>
                }

                <div class="pagination-info">
                    SAYFA @Model.CurrentPage / @Model.TotalPages
                </div>

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="?page=@(Model.CurrentPage + 1)" class="nav-btn btn-white">SONRAKİ →</a>
                }
                else
                {
                    <span class="btn-disabled">SONRAKİ →</span>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.siteUsers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllUsers.Select(u => new { username = u.Username, displayName = u.DisplayName, avatarColor = u.AvatarColor })));

        function toggleReadMore(btn) {
            const container = btn.closest('.tweet-content-container, .reply-content-container');
            const shortContent = container.querySelector('.short-content');
            const fullContent = container.querySelector('.full-content');
            
            if (shortContent.style.display === 'none') {
                shortContent.style.display = 'block';
                fullContent.style.display = 'none';
            } else {
                shortContent.style.display = 'none';
                fullContent.style.display = 'block';
            }
        }

        function openQuote(tweetId, authorName, content) {
            document.getElementById('QuoteTweetId').value = tweetId;
            document.getElementById('quotePreviewAuthor').textContent = "Gönderen: " + authorName;
            document.getElementById('quotePreviewText').textContent = content;
            document.getElementById('quotePreviewBox').style.display = 'block';
            
            // Scroll to the composer form
            document.querySelector('.left-column').scrollIntoView({ behavior: 'smooth' });
        }

        function cancelQuote() {
            document.getElementById('QuoteTweetId').value = '';
            document.getElementById('quotePreviewBox').style.display = 'none';
        }

        function toggleReplyForm(btn) {
            const wrapper = btn.nextElementSibling;
            if (wrapper.style.display === 'none' || wrapper.style.display === '') {
                wrapper.style.display = 'block';
                btn.textContent = '❌ CEVAPLAMAYI KAPAT';
            } else {
                wrapper.style.display = 'none';
                btn.textContent = '💬 CEVAP YAZ';
            }
        }

        // Inline Tweet Edit
        function startEditTweet(id) {
            document.getElementById(`tweet-content-container-${id}`).style.display = 'none';
            document.getElementById(`edit-tweet-form-container-${id}`).style.display = 'block';
        }
        function cancelEditTweet(id) {
            document.getElementById(`tweet-content-container-${id}`).style.display = 'block';
            document.getElementById(`edit-tweet-form-container-${id}`).style.display = 'none';
        }

        // Inline Reply Edit
        function startEditReply(id) {
            document.getElementById(`reply-content-container-${id}`).style.display = 'none';
            document.getElementById(`edit-reply-form-container-${id}`).style.display = 'block';
        }
        function cancelEditReply(id) {
            document.getElementById(`reply-content-container-${id}`).style.display = 'block';
            document.getElementById(`edit-reply-form-container-${id}`).style.display = 'none';
        }
    </script>
}
